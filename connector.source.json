{
  "schemaVersion": 1,
  "extensionId": "irodori.couchbase",
  "visibility": "public",
  "version": "0.1.0",
  "connector": {
    "id": "couchbase.connector",
    "engine": "couchbase",
    "label": "Couchbase",
    "aliases": [
      "couchbase",
      "Couchbase"
    ],
    "defaultPort": 11210,
    "wire": "document",
    "module": "couchbase.driver",
    "features": [
      "metadata"
    ]
  },
  "connection": {
    "endpoint": {
      "modes": [
        "connectionString",
        "hostPort"
      ],
      "defaultPort": 11210,
      "fields": [
        {
          "id": "host",
          "label": "Host",
          "type": "string",
          "profileField": "host",
          "required": true
        },
        {
          "id": "port",
          "label": "Port",
          "type": "number",
          "profileField": "port",
          "default": 11210
        },
        {
          "id": "bucket",
          "label": "Bucket",
          "type": "string",
          "profileField": "database"
        },
        {
          "id": "scope",
          "label": "Scope",
          "type": "string",
          "option": "scope"
        },
        {
          "id": "collection",
          "label": "Collection",
          "type": "string",
          "option": "collection"
        }
      ]
    },
    "authMethods": [
      "none",
      "connectionString",
      "userPassword",
      "clientCertificate",
      "ldap",
      "saml",
      "oidc",
      "customDriverOptions"
    ],
    "tls": "optional",
    "transports": "default",
    "optionNamespaces": [
      "document",
      "couchbase"
    ],
    "customDriverOptions": true
  },
  "runtime": {
    "driverLinked": false
  },
  "source": {
    "knowledgeEngineStatus": "recognized_no_connector",
    "adapter": null
  }
}
